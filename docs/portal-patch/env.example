# Portal-side analytics embed configuration.
# Keep this file as placeholders only; store real values in local or deployment env.

# Use HTTPS in production.
ANALYTICS_EMBED_URL=https://<analytics-domain>/embed/overview

# Must match the analytics app's EMBED_JWT_SECRET.
# Server-only: do not expose this value to browser code.
ANALYTICS_EMBED_SECRET=replace-with-shared-secret

ANALYTICS_EMBED_ISSUER=grizcam_portal
ANALYTICS_EMBED_AUDIENCE=grizcam_analytics
ANALYTICS_EMBED_TOKEN_TTL=15m
