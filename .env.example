PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=grizcam_synthetic_2025
PGUSER=
PGPASSWORD=
DEMO_EXPORTS_ENABLED=false
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
REPORT_PROMPT_VERSION=v1
# Preferred for a dedicated writable reports store. Optional if DATABASE_URL is writable.
REPORTS_DATABASE_URL=
VITE_API_BASE_URL=
VITE_DEMO_EXPORTS_ENABLED=false
VITE_DEMO_LABEL=Synthetic data demo
VITE_APP_TITLE=GrizCam Demo | Yellowstone 2025 Analytics

# Portal embedding / GrizCam Portal integration
# VITE_* variables are frontend-safe and may be included in the browser bundle.
VITE_PORTAL_EMBED_MODE_ENABLED=false
VITE_PORTAL_PARENT_ORIGIN=
VITE_PORTAL_BRAND_LABEL=GrizCam Portal
VITE_EMBED_DEFAULT_ROUTE=/embed/overview

# EMBED_AUTH_MODE=jwt will be used in later tasks for signed portal embed tokens.
# EMBED_JWT_SECRET is server-only, must never be committed, and should be set from secret storage.
# PORTAL_ALLOWED_FRAME_ANCESTORS is backend runtime config; Vercel static frame headers live in vercel.json.
EMBED_AUTH_MODE=disabled
EMBED_JWT_SECRET=
EMBED_TOKEN_ISSUER=grizcam_portal
EMBED_TOKEN_AUDIENCE=grizcam_analytics
PORTAL_ALLOWED_FRAME_ANCESTORS=

# Future optional Cosmos sync variables. The fixture dry run does not require these.
# Do not commit real keys; store secrets in local .env files or deployment secret storage.
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE_ID=
COSMOS_EVENTS_CONTAINER_ID=
COSMOS_EVENT_ANALYSIS_CONTAINER_ID=
